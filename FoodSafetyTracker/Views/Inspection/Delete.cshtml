@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Delete Inspection";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger"><i class="bi bi-trash me-2"></i>Delete Inspection</h2>
    <a href="/Inspection" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card shadow-sm border-danger" style="max-width:500px">
    <div class="card-body">
        <p>Are you sure you want to delete this inspection and all its follow-ups?</p>
        <dl class="row">
            <dt class="col-sm-4">Premises</dt><dd class="col-sm-8">@Model.Premises.Name</dd>
            <dt class="col-sm-4">Date</dt><dd class="col-sm-8">@Model.InspectionDate.ToString("dd MMM yyyy")</dd>
            <dt class="col-sm-4">Outcome</dt><dd class="col-sm-8">@Model.Outcome</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Yes, Delete</button>
            <a href="/Inspection" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
