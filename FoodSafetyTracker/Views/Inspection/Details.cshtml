@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = $"Inspection #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-clipboard-check me-2"></i>Inspection #@Model.Id</h2>
    <div>
        @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
        {
            <a href="/FollowUp/Create/@Model.Id" class="btn btn-sm btn-warning me-2">
                <i class="bi bi-plus-lg me-1"></i>Add Follow-Up
            </a>
        }
        <a href="/Inspection" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-white fw-semibold">Inspection Details</div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Premises</dt>
            <dd class="col-sm-9"><a href="/Premises/Details/@Model.PremisesId">@Model.Premises.Name</a></dd>
            <dt class="col-sm-3">Town</dt>
            <dd class="col-sm-9">@Model.Premises.Town</dd>
            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.InspectionDate.ToString("dd MMMM yyyy")</dd>
            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">@Model.Score / 100</dd>
            <dt class="col-sm-3">Outcome</dt>
            <dd class="col-sm-9">
                <span class="badge fs-6 @(Model.Outcome == InspectionOutcome.Pass ? "bg-success" : "bg-danger")">@Model.Outcome</span>
            </dd>
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
        </dl>
    </div>
</div>

<h4 class="mb-3">Follow-Ups</h4>

@if (!Model.FollowUps.Any())
{
    <p class="text-muted">No follow-ups for this inspection.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr><th>Due Date</th><th>Status</th><th>Closed Date</th><th>Notes</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var f in Model.FollowUps)
                {
                    var overdue = f.Status == FollowUpStatus.Open && f.DueDate < DateTime.UtcNow;
                    <tr class="@(overdue ? "table-danger" : "")">
                        <td>
                            @f.DueDate.ToString("dd MMM yyyy")
                            @if (overdue) { <span class="badge bg-danger ms-1">OVERDUE</span> }
                        </td>
                        <td><span class="badge @(f.Status == FollowUpStatus.Closed ? "bg-success" : "bg-secondary")">@f.Status</span></td>
                        <td>@(f.ClosedDate?.ToString("dd MMM yyyy") ?? "—")</td>
                        <td>@(f.Notes ?? "—")</td>
                        <td>
                            @if (f.Status == FollowUpStatus.Open && (User.IsInRole("Admin") || User.IsInRole("Inspector")))
                            {
                                <a href="/FollowUp/Close/@f.Id" class="btn btn-sm btn-success">Close</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
