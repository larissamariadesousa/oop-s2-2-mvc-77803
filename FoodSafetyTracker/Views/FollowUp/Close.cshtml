@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Close Follow-Up";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-check2-circle me-2"></i>Close Follow-Up</h2>
    <a href="/Inspection/Details/@Model.InspectionId" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-4">Due Date</dt><dd class="col-sm-8">@Model.DueDate.ToString("dd MMM yyyy")</dd>
            <dt class="col-sm-4">Notes</dt><dd class="col-sm-8">@(Model.Notes ?? "—")</dd>
        </dl>

        <form asp-action="Close" method="post">
            <input name="id" type="hidden" value="@Model.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-4">
                <label class="form-label fw-semibold">Closed Date <span class="text-danger">*</span></label>
                <input name="closedDate" type="date" class="form-control"
                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                <div class="form-text">A closed date is required to complete this follow-up.</div>
            </div>

            <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Mark as Closed</button>
            <a href="/Inspection/Details/@Model.InspectionId" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
