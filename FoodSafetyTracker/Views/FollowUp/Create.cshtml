@model FoodSafetyTracker.Models.CreateFollowUpViewModel
@{
    ViewData["Title"] = "Add Follow-Up";
    var inspection = ViewBag.Inspection as FoodSafetyTracker.Models.Inspection;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-plus me-2"></i>Add Follow-Up</h2>
    <a href="/Inspection/Details/@Model.InspectionId" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (inspection != null)
{
    <div class="alert alert-info mb-3">
        <strong>Inspection:</strong> @inspection.Premises.Name — @inspection.InspectionDate.ToString("dd MMM yyyy") — Score: @inspection.Score (@inspection.Outcome)
    </div>
}

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <input asp-for="InspectionId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label fw-semibold">Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
                <span asp-validation-for="DueDate" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold">Notes (optional)</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Add Follow-Up</button>
            <a href="/Inspection/Details/@Model.InspectionId" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
