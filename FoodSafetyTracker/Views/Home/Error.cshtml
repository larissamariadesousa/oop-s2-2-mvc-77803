@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:4rem"></i>
    <h1 class="mt-3">Something went wrong</h1>
    <p class="text-muted mb-4">An unexpected error occurred. The issue has been logged and our team will look into it.</p>
    @if (ViewBag.RequestId != null)
    {
        <p class="small text-muted">Request ID: <code>@ViewBag.RequestId</code></p>
    }
    <a href="/" class="btn btn-primary mt-2"><i class="bi bi-house me-1"></i>Return Home</a>
</div>
